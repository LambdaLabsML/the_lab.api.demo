# Default environment for all experiments.
# Sourced by run_experiment.sh before the experiment script runs.
# Experiment scripts may override any of these by exporting their own values.

export GEMMA4_ASSISTANT_ENABLED="${GEMMA4_ASSISTANT_ENABLED:-0}"
export EXTRA_ARGS="${EXTRA_ARGS:-}"
export VLLM_USE_V2_MODEL_RUNNER="${VLLM_USE_V2_MODEL_RUNNER:-0}"
export WATCHDOG_ENABLED="${WATCHDOG_ENABLED:-0}"
export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda}"
export CUDA_PATH="${CUDA_PATH:-/usr/local/cuda}"
export PATH="$HOME/bin:$HOME/.thelab/base-venv/bin:$HOME/.local/bin:/usr/local/cuda/bin:${PATH}"
